vector <int> calculateSpan(int price[], int n)
    {
       // Your code here
       vector<int> ans(n,0);
       ans[0]=1;
       stack<int> stk;
       stk.push(0);
       for(int i=1;i<n;i++){
           
           while(!stk.empty() && price[stk.top()]<=price[i]) stk.pop();
           
           if(stk.empty()) ans[i]=i+1;
           else{
               ans[i]=i-stk.top();
           }
           stk.push(i);
       }
       return ans;
    }
