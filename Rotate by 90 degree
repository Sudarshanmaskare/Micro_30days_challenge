void rotate(vector<vector<int> >& a)
{ 
    int n=a.size();
    // Your code goes here
     for(int i=0;i<n;i++){
        int end=n-1,start=0;
        while(start<end){
            swap(a[i][start],a[i][end]);
            start++;
            end--;
        }
    }
    for(int i=0;i<n;i++){
        for(int j=i;j<n;j++){
            swap(a[i][j],a[j][i]);
        }
    }
}
