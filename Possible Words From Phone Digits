#include <string>

using namespace std;


 // } Driver Code Ends
//User function Template for C++

class Solution
{
    int index;
    string cur;
    string alpha[10] = {"", "", "abc", "def", "ghi", "jkl", "mno", "pqrs", "tuv", "wxyz"};
    
    void cal(int a[],vector<string> &res,int N){
        if(N==index){
            res.push_back(cur);
            return;
        }
        
        for(int i=0;i<alpha[a[index]].size();i++){
            cur.push_back(alpha[a[index]][i]);
            index++;
            cal(a,res,N);
            index--;
            cur.pop_back();
        }
    }
    public:
    vector<string> possibleWords(int a[], int N)
    {
        vector<string> res;
        index=0;
        cal(a,res,N);
        return res;
    }
};


