#include<bits/stdc++.h>
using namespace std;

 // } Driver Code Ends
class Solution
{
    public:
    //Function to find unit area of the largest region of 1s.
     int bfs(vector<vector<int>>& grid,int i,int j,int n,int m){
    int x_path[]={1,1,0,-1,-1,-1,0,1};
    int y_path[]={0,1,1,1,0,-1,-1,-1};
    
    int cnt=1;
    
    queue<pair<int,int>> Q;
    Q.push(make_pair(i,j));
    grid[i][j]=2;
    
    while(!Q.empty()){
        int x=Q.front().first;
        int y=Q.front().second;
        Q.pop();
        
        for(int i=0;i<8;i++){
            int xx=x+x_path[i];
            int yy=y+y_path[i];
            
            if(xx>=0 && yy>=0 && xx<n && yy<m && grid[xx][yy]==1){
                cnt++;
                Q.push(make_pair(xx,yy));
                grid[xx][yy]=2;
            }
        }
        
    }
    
    return cnt;
    
    }
    int findMaxArea(vector<vector<int>>& grid) {
        // Code here
        int cnt=0;
        int r=grid.size();
        int c=grid[0].size();
        for(int i=0;i<r;i++){
            for(int j=0;j<c;j++){
                if(grid[i][j]==1){
                    int val=bfs(grid,i,j,r,c);
                    cnt=max(cnt,val);
                }
            }
        }
        return cnt;
    }
};

